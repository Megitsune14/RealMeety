# Production — copier vers .env sur le VPS

# Domaine
DOMAIN=realmeety.fr
ACME_EMAIL=admin@realmeety.fr
APP_URL=https://realmeety.fr
CORS_ORIGIN=https://realmeety.fr
API_BASE_URL=https://api.realmeety.fr

# Secrets (générer : openssl rand -base64 32)
JWT_SECRET=

# MongoDB Atlas (cluster UE — Frankfurt ou Paris)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/realmeety?retryWrites=true&w=majority

# Stripe Identity KYC
KYC_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Beta terrain — zone de test (ex. Paris Marais)
BETA_MODE=true
BETA_CENTER_LAT=48.8566
BETA_CENTER_LNG=2.3522
BETA_RADIUS_METERS=5000
